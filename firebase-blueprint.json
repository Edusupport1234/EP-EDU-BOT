{
  "entities": {
    "knowledgeChunks": {
      "title": "Knowledge Chunk",
      "description": "A piece of information used to train the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "title": { "type": "string", "description": "Short title for the info" },
        "content": { "type": "string", "description": "The actual knowledge content" },
        "summary": { "type": "string", "description": "A brief summary of the content" },
        "category": { "type": "string", "description": "Primary category (e.g., CFF, Schedule)" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for categorization" },
        "createdAt": { "type": "number", "description": "Creation timestamp" },
        "updatedAt": { "type": "number", "description": "Last update timestamp" },
        "userId": { "type": "string", "description": "The user who owns this knowledge" },
        "fileType": { "type": "string", "description": "The MIME type of the uploaded file" },
        "fileName": { "type": "string", "description": "The name of the uploaded file" }
      },
      "required": ["id", "title", "content", "summary", "category", "userId"]
    },
    "chatSessions": {
      "title": "Chat Session",
      "description": "A conversation session between a user and the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "lastMessage", "updatedAt", "createdAt"]
    },
    "chatMessages": {
      "title": "Chat Message",
      "description": "An individual message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/knowledgeChunks/{chunkId}": {
      "schema": "knowledgeChunks",
      "description": "User-managed knowledge base for the chatbot."
    },
    "/chatSessions/{sessionId}": {
      "schema": "chatSessions",
      "description": "User chat sessions."
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": "chatMessages",
      "description": "Messages within a specific chat session."
    }
  }
}
